@if (IsVisible)
{
    <div class="modal-overlay" @onclick:stopPropagation @onclick="OnClose">
        <div class="modal-card" @onclick:stopPropagation style="@MaxWidthStyle">
            <h5 class="mb-3">@Title</h5>
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string? MaxWidth { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string? MaxWidthStyle =>
        !string.IsNullOrEmpty(MaxWidth) ? $"max-width:{MaxWidth}" : null;
}
