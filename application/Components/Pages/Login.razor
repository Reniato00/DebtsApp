@page "/login"
@layout Layout.BlankLayout
@inject services.Services.IAuthService Auth
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Iniciar sesión</PageTitle>

<div class="login-card">
    <h2>DebtsApp</h2>
    <p class="subtitle">Gestiona tus deudas y pagos</p>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger py-2 small">@Error</div>
    }

    @if (ShowRegister)
    {
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input @bind="Name" class="form-control" placeholder="Tu nombre" />
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Correo electrónico</label>
        <input type="email" @bind="Email" class="form-control" placeholder="correo@ejemplo.com" />
    </div>

    <div class="mb-4">
        <label class="form-label">Contraseña</label>
        <input type="password" @bind="Password" class="form-control" placeholder="••••••" />
    </div>

    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@Loading">
        @if (Loading)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            <span>@(ShowRegister ? "Registrando..." : "Ingresando...")</span>
        }
        else
        {
            <span>@(ShowRegister ? "Registrarse" : "Ingresar")</span>
        }
    </button>

    <div class="text-center mt-3">
        <a href="javascript:void(0)" @onclick="ToggleMode" class="text-muted small">
            @(ShowRegister ? "¿Ya tienes cuenta? Inicia sesión" : "¿No tienes cuenta? Regístrate")
        </a>
    </div>
</div>

@code {
    private string Email = "";
    private string Password = "";
    private string Name = "";
    private string Error = "";
    private bool Loading;
    private bool ShowRegister;

    private void ToggleMode()
    {
        ShowRegister = !ShowRegister;
        Error = "";
    }

    private async Task SubmitAsync()
    {
        Error = "";
        Loading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                Error = "El correo es requerido";
                return;
            }
            if (string.IsNullOrWhiteSpace(Password))
            {
                Error = "La contraseña es requerida";
                return;
            }

            var provider = (application.Auth.CustomAuthStateProvider)AuthState;

            if (ShowRegister)
            {
                if (string.IsNullOrWhiteSpace(Name))
                {
                    Error = "El nombre es requerido";
                    return;
                }
                var (accessToken, _, _) = await Auth.RegisterAsync(Email, Name, Password);
                var (userId, userName) = DecodeToken(accessToken);
                provider.SignIn(userId, userName);
            }
            else
            {
                var (accessToken, _, _) = await Auth.LoginAsync(Email, Password);
                var (userId, userName) = DecodeToken(accessToken);
                provider.SignIn(userId, userName);
            }

            Nav.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }

    private static (Guid userId, string userName) DecodeToken(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length < 2) return (Guid.Empty, "");
            var payload = parts[1];
            var len = payload.Length % 4;
            if (len == 2) payload += "==";
            else if (len == 3) payload += "=";
            payload = payload.Replace('-', '+').Replace('_', '/');
            var bytes = Convert.FromBase64String(payload);
            var json = System.Text.Encoding.UTF8.GetString(bytes);
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var uid = Guid.Empty;
            foreach (var key in new[] { "nameid", "sub", "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier" })
                if (doc.RootElement.TryGetProperty(key, out var prop) && Guid.TryParse(prop.GetString(), out uid))
                    break;
            var name = "";
            foreach (var key in new[] { "unique_name", "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name" })
                if (doc.RootElement.TryGetProperty(key, out var prop))
                    name = prop.GetString() ?? "";
            return (uid, name);
        }
        catch { }
        return (Guid.Empty, "");
    }
}
