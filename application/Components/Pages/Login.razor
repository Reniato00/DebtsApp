@page "/login"
@layout Layout.BlankLayout
@using Microsoft.Extensions.Configuration
@inject services.Services.IAuthService Auth
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IConfiguration Config

<PageTitle>Iniciar sesión</PageTitle>

<div class="login-card">
    <h2>DebtsApp</h2>
    <p class="subtitle">Gestiona tus deudas y pagos</p>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger py-2 small">@Error</div>
    }

    @if (ShowRegister)
    {
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input @bind="Name" class="form-control" placeholder="Tu nombre" />
        </div>
        <div class="mb-3 d-flex justify-content-center">
            <Turnstile SiteKey="@TurnstileSiteKey" TokenChanged="(t) => TurnstileToken = t" Expired="() => TurnstileToken = null" />
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Correo electrónico</label>
        <input type="email" @bind="Email" class="form-control" placeholder="correo@ejemplo.com" />
    </div>

    <div class="mb-3">
        <label class="form-label">Contraseña</label>
        <div class="input-group">
            <input type="@(ShowPassword ? "text" : "password")" value="@Password" @oninput="OnPasswordInput" class="form-control" placeholder="••••••" />
            <button class="btn btn-outline-secondary" type="button" @onclick="() => ShowPassword = !ShowPassword" tabindex="-1">
                @(ShowPassword ? "🙈" : "👁")
            </button>
        </div>
    </div>

    @if (ShowRegister && !string.IsNullOrEmpty(Password))
    {
        <div class="mb-3 small">
            <div class="@(PwdHasLength ? "text-success" : "text-muted")">@(PwdHasLength ? "✔" : "✘") Mínimo 8 caracteres</div>
            <div class="@(PwdHasUpper ? "text-success" : "text-muted")">@(PwdHasUpper ? "✔" : "✘") Al menos una mayúscula</div>
            <div class="@(PwdHasLower ? "text-success" : "text-muted")">@(PwdHasLower ? "✔" : "✘") Al menos una minúscula</div>
            <div class="@(PwdHasDigit ? "text-success" : "text-muted")">@(PwdHasDigit ? "✔" : "✘") Al menos un número</div>
            <div class="@(PwdHasSpecial ? "text-success" : "text-muted")">@(PwdHasSpecial ? "✔" : "✘") Al menos un carácter especial (!@@#$%^&*)</div>
        </div>
    }

    @if (ShowRegister)
    {
        <div class="mb-3">
            <label class="form-label">Confirmar contraseña</label>
            <div class="input-group">
                <input type="@(ShowConfirmPassword ? "text" : "password")" @bind="ConfirmPassword" class="form-control" placeholder="••••••" />
                <button class="btn btn-outline-secondary" type="button" @onclick="() => ShowConfirmPassword = !ShowConfirmPassword" tabindex="-1">
                    @(ShowConfirmPassword ? "🙈" : "👁")
                </button>
            </div>
        </div>
        <div class="mb-3 form-check">
            <input type="checkbox" @bind="AcceptTerms" class="form-check-input" id="acceptTerms" />
            <label class="form-check-label small" for="acceptTerms">
                Declaro ser mayor de 18 años y acepto los <a href="terms" target="_blank">Términos y Condiciones</a>
            </label>
        </div>
    }
    else
    {
        <div class="mb-4"></div>
    }

    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@(Loading || (ShowRegister && !RegisterEnabled))">
        @if (Loading)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            <span>@(ShowRegister ? "Registrando..." : "Ingresando...")</span>
        }
        else
        {
            <span>@(ShowRegister ? "Registrarse" : "Ingresar")</span>
        }
    </button>

    <div class="text-center mt-3">
        <a href="javascript:void(0)" @onclick="ToggleMode" class="text-muted small">
            @(ShowRegister ? "¿Ya tienes cuenta? Inicia sesión" : "¿No tienes cuenta? Regístrate")
        </a>
    </div>

    <div class="text-center mt-2">
        <a href="terms" class="text-muted small">
            Términos y condiciones
        </a>
    </div>
</div>

@code {
    private string Email = "";
    private string Password = "";
    private string ConfirmPassword = "";
    private string Name = "";
    private string Error = "";
    private bool Loading;
    private bool ShowRegister;
    private bool AcceptTerms;
    private string? TurnstileToken;
    private string TurnstileSiteKey => Config["Turnstile:SiteKey"] ?? "";
    private bool ShowPassword;
    private bool ShowConfirmPassword;

    private bool PwdHasLength => Password.Length >= 8;
    private bool PwdHasUpper => Password.Any(char.IsUpper);
    private bool PwdHasLower => Password.Any(char.IsLower);
    private bool PwdHasDigit => Password.Any(char.IsDigit);
    private bool PwdHasSpecial => Password.Any(c => !char.IsLetterOrDigit(c));
    private bool PwdValid => PwdHasLength && PwdHasUpper && PwdHasLower && PwdHasDigit && PwdHasSpecial;
    private bool RegisterEnabled => PwdValid && !string.IsNullOrWhiteSpace(Name) && !string.IsNullOrWhiteSpace(Email) && Password == ConfirmPassword && AcceptTerms;

    private void OnPasswordInput(ChangeEventArgs e)
    {
        Password = e.Value?.ToString() ?? "";
    }

    private void ToggleMode()
    {
        ShowRegister = !ShowRegister;
        Error = "";
        Password = "";
        ConfirmPassword = "";
        ShowPassword = false;
        ShowConfirmPassword = false;
        TurnstileToken = null;
    }

    private async Task SubmitAsync()
    {
        Error = "";
        Loading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                Error = "El correo es requerido";
                return;
            }

            if (string.IsNullOrWhiteSpace(Password))
            {
                Error = "La contraseña es requerida";
                return;
            }

            if (ShowRegister)
            {
                if (string.IsNullOrWhiteSpace(Name))
                {
                    Error = "El nombre es requerido";
                    return;
                }

                if (Password != ConfirmPassword)
                {
                    Error = "Las contraseñas no coinciden";
                    return;
                }

                if (!AcceptTerms)
                {
                    Error = "Debes aceptar los términos y condiciones y declarar ser mayor de 18 años";
                    return;
                }
            }

            var provider = (application.Auth.CustomAuthStateProvider)AuthState;

            if (ShowRegister)
            {
                var (userId, userName) = await Auth.RegisterAsync(Email, Name, Password, "1.0", TurnstileToken);
                provider.SignIn(userId, userName);
            }
            else
            {
                var (userId, userName) = await Auth.LoginAsync(Email, Password);
                provider.SignIn(userId, userName);
            }

            Nav.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }
}
