@page "/calculator"
@using domain.Entities
@using services.Models
@inject services.Services.ICalculatorService CalcService
@inject services.Services.IDebtService DebtService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Calculadora</PageTitle>

<h3 class="mb-4">Calculadora</h3>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(ActiveTab == "strategy" ? "active" : "")" href="javascript:void(0)" @onclick="ShowStrategy">Estrategia de pago</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ActiveTab == "daily" ? "active" : "")" href="javascript:void(0)" @onclick="ShowDaily">Interés diario</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ActiveTab == "prepayment" ? "active" : "")" href="javascript:void(0)" @onclick="ShowPrepayment">Simular prepago</a>
    </li>
</ul>

@if (ActiveTab == "strategy")
{
    @* ───── Estrategia Snowball / Avalanche ───── *@
    <div class="card p-4 mb-4">
        <h5 class="section-title">Estrategia de pago</h5>
        <p class="text-muted small">Snowball: paga primero la deuda más pequeña. Avalanche: paga primero la de mayor interés.</p>

        <div class="d-flex gap-2 align-items-end mb-3">
            <div style="max-width:250px">
                <label class="form-label">Pago mensual disponible</label>
                <input type="number" step="0.01" @bind="MonthlyPayment" class="form-control" />
            </div>
            <button class="btn btn-primary" @onclick="LoadStrategyAsync" disabled="@StrategyLoading">Calcular</button>
        </div>

        @if (StrategyLoading)
        {
            <div class="d-flex justify-content-center py-3">
                <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
            </div>
        }
        else if (StrategyResult != null)
        {
            <ul class="nav nav-pills mb-3 gap-2">
                <li class="nav-item">
                    <a class="nav-link @(ShowAvalanche ? "" : "active")" href="javascript:void(0)" @onclick="() => ShowAvalanche = false">
                        Snowball (@StrategyResult.SnowballMonths meses)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ShowAvalanche ? "active" : "")" href="javascript:void(0)" @onclick="() => ShowAvalanche = true">
                        Avalanche (@StrategyResult.AvalancheMonths meses)
                    </a>
                </li>
            </ul>

            <div class="alert alert-info py-2 small mb-3">
                @if (ShowAvalanche)
                {
                    <text><strong>Avalanche:</strong> Ordena las deudas de mayor a menor tasa de inter&eacute;s. Pagas el m&iacute;nimo en todas excepto la de inter&eacute;s m&aacute;s alto. Es la estrategia &oacute;ptima matem&aacute;ticamente &mdash; pagar&aacute;s menos intereses totales.</text>
                }
                else
                {
                    <text><strong>Snowball:</strong> Ordena las deudas de menor a mayor saldo. Pagas el m&iacute;nimo en todas excepto la m&aacute;s peque&ntilde;a. La ventaja es psicol&oacute;gica &mdash; al liquidar deudas r&aacute;pido te motiva a seguir.</text>
                }
            </div>

            var steps = Steps;
            var totalMonths = TotalMonths;

            @if (steps.Count == 0)
            {
                <p class="text-muted">No hay deudas activas para calcular.</p>
            }
            else
            {
                <div class="table-responsive" style="max-height:400px; overflow-y:auto">
                    <table class="table table-sm table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Mes</th>
                                <th>Deuda</th>
                                <th>Pago</th>
                                <th>Saldo restante</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in steps)
                            {
                                <tr>
                                    <td>@s.Month</td>
                                    <td>@s.DebtName</td>
                                    <td>@FormatMoney(s.PaymentAmount)</td>
                                    <td>@FormatMoney(s.RemainingBalance)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <p class="text-muted small mt-2">Total: <strong>@totalMonths meses</strong> (@(totalMonths / 12) años @(totalMonths % 12) meses)</p>
            }
        }
    </div>
}
else if (ActiveTab == "daily")
{
    @* ───── Interés Diario ───── *@
    <div class="card p-4 mb-4">
        <h5 class="section-title">Interés diario por deuda</h5>
        <p class="text-muted small">Monto que se acumula cada día en intereses.</p>

        @if (DailyLoading)
        {
            <div class="d-flex justify-content-center py-3">
                <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
            </div>
        }
        else if (DailyResult != null)
        {
            @if (DailyResult.Items.Count == 0)
            {
                <p class="text-muted">No hay deudas activas.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Deuda</th>
                                <th>Saldo actual</th>
                                <th>Tasa %</th>
                                <th>Interés diario</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in DailyResult.Items)
                            {
                                <tr>
                                    <td>@item.DebtName</td>
                                    <td>@FormatMoney(item.CurrentBalance)</td>
                                    <td>@item.InterestRate.ToString("N1")%</td>
                                    <td class="negative">@FormatMoney(item.DailyInterest)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="3">Total interés diario</td>
                                <td class="negative">@FormatMoney(DailyResult.TotalDailyInterest)</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <p class="text-muted small">
                    Interés mensual estimado: <strong>@FormatMoney(DailyResult.TotalDailyInterest * 30)</strong>
                    &nbsp;|&nbsp; Anual: <strong>@FormatMoney(DailyResult.TotalDailyInterest * 365)</strong>
                </p>
            }
        }
    </div>
}
else if (ActiveTab == "prepayment")
{
    @* ───── Simulador de Prepago ───── *@
    <div class="card p-4 mb-4">
        <h5 class="section-title">Simular prepago</h5>
        <p class="text-muted small">Calcula el impacto de hacer un pago extra a una deuda específica.</p>

        <div class="d-flex gap-3 align-items-end mb-3 flex-wrap">
            <div style="min-width:250px">
                <label class="form-label">Deuda</label>
                <select @bind="PrepaymentDebtId" class="form-select">
                    <option value="">Seleccionar...</option>
                    @foreach (var d in DebtList)
                    {
                        <option value="@d.Id">@d.Name — @FormatMoney(d.CurrentBalance)</option>
                    }
                </select>
            </div>
            <div style="max-width:200px">
                <label class="form-label">Pago extra ($)</label>
                <input type="number" min="0" step="0.01" @bind="PrepaymentExtraAmount" class="form-control" />
            </div>
            <button class="btn btn-primary" @onclick="LoadPrepaymentAsync" disabled="@PrepaymentLoading">Calcular</button>
        </div>

        @if (PrepaymentLoading)
        {
            <div class="d-flex justify-content-center py-3">
                <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
            </div>
        }
        else if (PrepaymentResult != null)
        {
            var r = PrepaymentResult;
            <div class="row g-3">
                @* ── Situación actual ── *@
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title">Situación actual</h6>
                            <hr />
                            <p class="mb-1"><strong>@r.DebtName</strong></p>
                            <p class="mb-1">Saldo: @FormatMoney(r.CurrentBalance)</p>
                            <p class="mb-1">Pago mensual: @FormatMoney(r.CurrentMonthlyPayment)</p>
                            <p class="mb-1">Meses restantes: <strong>@r.CurrentRemainingMonths</strong></p>
                            <p class="mb-0">Interés total: <span class="negative">@FormatMoney(r.CurrentTotalInterest)</span></p>
                        </div>
                    </div>
                </div>

                @* ── Reducir plazo ── *@
                <div class="col-md-4">
                    <div class="card h-100 border-success">
                        <div class="card-body">
                            <h6 class="card-title text-success">Reducir plazo</h6>
                            <p class="text-muted small">Misma mensualidad, menos meses.</p>
                            <hr />
                            <p class="mb-1">Pago mensual: @FormatMoney(r.ReduceTerm.NewMonthlyPayment)</p>
                            <p class="mb-1">Meses restantes: <strong>@r.ReduceTerm.RemainingMonths</strong></p>
                            @if (r.ReduceTerm.MonthsSaved > 0)
                            {
                                <p class="mb-1 text-success">Te ahorras <strong>@r.ReduceTerm.MonthsSaved meses</strong></p>
                            }
                            <p class="mb-1">Interés total: <span class="negative">@FormatMoney(r.ReduceTerm.TotalInterest)</span></p>
                            @if (r.ReduceTerm.InterestSaved > 0)
                            {
                                <p class="mb-0 text-success">Ahorras @FormatMoney(r.ReduceTerm.InterestSaved) en intereses</p>
                            }
                            @if (r.ReduceTerm.PayoffDate.HasValue)
                            {
                                <p class="mb-0 small text-muted">Pagas en: @r.ReduceTerm.PayoffDate.Value.ToString("MMM yyyy")</p>
                            }
                        </div>
                    </div>
                </div>

                @* ── Reducir cuota ── *@
                <div class="col-md-4">
                    <div class="card h-100 border-info">
                        <div class="card-body">
                            <h6 class="card-title text-info">Reducir cuota</h6>
                            <p class="text-muted small">Mismo plazo, menos pago mensual.</p>
                            <hr />
                            <p class="mb-1">Nuevo pago: @FormatMoney(r.ReducePayment.NewMonthlyPayment)</p>
                            @if (r.CurrentMonthlyPayment > 0)
                            {
                                var savedPerMonth = r.CurrentMonthlyPayment - r.ReducePayment.NewMonthlyPayment;
                                <p class="mb-1 text-info">Pagas @FormatMoney(savedPerMonth) menos al mes</p>
                            }
                            <p class="mb-1">Meses restantes: <strong>@r.ReducePayment.RemainingMonths</strong></p>
                            <p class="mb-1">Interés total: <span class="negative">@FormatMoney(r.ReducePayment.TotalInterest)</span></p>
                            @if (r.ReducePayment.InterestSaved > 0)
                            {
                                <p class="mb-0 text-success">Ahorras @FormatMoney(r.ReducePayment.InterestSaved) en intereses</p>
                            }
                            @if (r.ReducePayment.PayoffDate.HasValue)
                            {
                                <p class="mb-0 small text-muted">Pagas en: @r.ReducePayment.PayoffDate.Value.ToString("MMM yyyy")</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

@code {
    private string ActiveTab = "strategy";
    private string? ErrorMessage;

    // Strategy
    private decimal MonthlyPayment = 1000;
    private bool StrategyLoading;
    private PayoffStrategyResult? StrategyResult;
    private bool ShowAvalanche;

    private List<PayoffStep> Steps =>
        ShowAvalanche ? (StrategyResult?.Avalanche ?? new()) : (StrategyResult?.Snowball ?? new());

    private int TotalMonths =>
        ShowAvalanche ? (StrategyResult?.AvalancheMonths ?? 0) : (StrategyResult?.SnowballMonths ?? 0);

    // Daily
    private bool DailyLoading;
    private DailyInterestResult? DailyResult;

    // Prepayment
    private List<Debt> DebtList = new();
    private Guid? PrepaymentDebtId;
    private decimal PrepaymentExtraAmount = 0;
    private bool PrepaymentLoading;
    private PrepaymentAnalysisResult? PrepaymentResult;

    private Guid UserId;

    private void ShowStrategy() { ActiveTab = "strategy"; ErrorMessage = null; }
    private void ShowDaily() { ActiveTab = "daily"; ErrorMessage = null; }
    private void ShowPrepayment() { ActiveTab = "prepayment"; ErrorMessage = null; }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var uid = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!Guid.TryParse(uid, out UserId))
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadDailyAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDebtsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadDebtsAsync()
    {
        try
        {
            DebtList = (await DebtService.GetAllDebtsAsync(UserId)).ToList();
        }
        catch
        {
        }
    }

    private async Task LoadStrategyAsync()
    {
        if (MonthlyPayment <= 0) return;
        StrategyLoading = true;
        StrategyResult = null;
        try
        {
            StrategyResult = await CalcService.GetPayoffStrategyAsync(UserId, MonthlyPayment);
        }
        catch
        {
        }
        finally
        {
            StrategyLoading = false;
        }
    }

    private async Task LoadDailyAsync()
    {
        DailyLoading = true;
        try
        {
            DailyResult = await CalcService.GetDailyInterestAsync(UserId);
        }
        catch
        {
        }
        finally
        {
            DailyLoading = false;
        }
    }

    private async Task LoadPrepaymentAsync()
    {
        ErrorMessage = null;
        if (!PrepaymentDebtId.HasValue)
        {
            ErrorMessage = "Selecciona una deuda.";
            return;
        }
        if (PrepaymentExtraAmount <= 0)
        {
            ErrorMessage = "El monto extra debe ser mayor a 0.";
            return;
        }

        PrepaymentLoading = true;
        PrepaymentResult = null;
        try
        {
            PrepaymentResult = await CalcService.AnalyzePrepaymentAsync(UserId,
                new PrepaymentAnalysisRequest { DebtId = PrepaymentDebtId.Value, ExtraAmount = PrepaymentExtraAmount });
        }
        catch
        {
            ErrorMessage = "Error al calcular. Verifica que el monto no supere el saldo.";
        }
        finally
        {
            PrepaymentLoading = false;
        }
    }

    private static string FormatMoney(decimal val) =>
        val.ToString("C0", new System.Globalization.CultureInfo("en-US"));
}
