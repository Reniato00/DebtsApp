@page "/"
@page "/dashboard"
@using persistence.Models
@using application.Models
@inject services.Services.IDashboardService DashboardSvc
@inject services.Services.IPaymentService PaymentService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Dashboard</PageTitle>

<h3 class="mb-4">Dashboard</h3>

@if (Summary == null)
{
    <LoadingSpinner FullPage="true" />
}
else
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total deudas</div>
            <div class="stat-value neutral">@Summary.TotalDebts</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Saldo total</div>
            <div class="stat-value negative">@FormattingHelpers.FormatMoney(Summary.TotalAmount)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Pago mensual total</div>
            <div class="stat-value negative">@FormattingHelpers.FormatMoney(Summary.TotalMonthlyPayment)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Tasa de interés promedio</div>
            <div class="stat-value neutral">@Summary.AverageInterestRate.ToString("N1")%</div>
        </div>
    </div>

    <div class="row g-4">
        @* ───── Próximos pagos ───── *@
        <div class="col-md-6">
            <div class="card p-3 h-100">
                <h5 class="section-title">Próximos pagos</h5>
                @if (Upcoming == null)
                {
                    <LoadingSpinner />
                }
                else if (Upcoming.Count == 0)
                {
                    <p class="text-muted small mb-0">No hay pagos próximos.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Deuda</th>
                                    <th>Monto</th>
                                    <th>Vence</th>
                                    <th>Días</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Upcoming)
                                {
                                    <tr class="@(p.DaysUntilDue <= 7 ? "table-warning" : "")">
                                        <td>@p.DebtName</td>
                                        <td>@FormattingHelpers.FormatMoney(p.Amount)</td>
                                        <td>@p.DueDate.ToShortDateString()</td>
                                        <td>@p.DaysUntilDue días</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* ───── Historial de pagos ───── *@
        <div class="col-md-6">
            <div class="card p-3 h-100">
                <h5 class="section-title">Últimos pagos</h5>
                @if (History == null)
                {
                    <LoadingSpinner />
                }
                else if (History.Count == 0)
                {
                    <p class="text-muted small mb-0">No hay pagos registrados.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Deuda</th>
                                    <th>Monto</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in History)
                                {
                                    <tr>
                                        <td>@p.DebtName</td>
                                        <td class="negative">@FormattingHelpers.FormatMoney(p.Amount)</td>
                                        <td>@p.PaymentDate.ToShortDateString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* ───── Pagado vs Pendiente ───── *@
        <div class="col-md-6">
            <div class="card p-3">
                <h5 class="section-title">Pagado vs Pendiente</h5>
                @if (PaidVsPending == null)
                {
                    <LoadingSpinner />
                }
                else
                {
                    <div class="d-flex gap-4">
                        <div>
                            <div class="stat-label">Pagado</div>
                            <div class="stat-value positive" style="font-size:1.4rem">@FormattingHelpers.FormatMoney(PaidVsPending.TotalPaid)</div>
                        </div>
                        <div>
                            <div class="stat-label">Pendiente</div>
                            <div class="stat-value negative" style="font-size:1.4rem">@FormattingHelpers.FormatMoney(PaidVsPending.TotalPending)</div>
                        </div>
                    </div>
                    <div class="progress mt-2" style="height:8px">
                        <div class="progress-bar bg-success" style="width:@(PaidPct)%"></div>
                        <div class="progress-bar bg-danger" style="width:@(100 - PaidPct)%"></div>
                    </div>
                    <small class="text-muted">@PaidPct.ToString("N0")% pagado</small>
                }
            </div>
        </div>

        @* ───── Costo de intereses ───── *@
        <div class="col-md-6">
            <div class="card p-3">
                <h5 class="section-title">Costo de intereses</h5>
                @if (InterestCost == null)
                {
                    <LoadingSpinner />
                }
                else if (InterestCost.Count == 0)
                {
                    <p class="text-muted small mb-0">No hay datos.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Deuda</th>
                                    <th>Pagado</th>
                                    <th>Restante</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in InterestCost)
                                {
                                    <tr>
                                        <td>@c.Name</td>
                                        <td>@FormattingHelpers.FormatMoney(c.TotalInterestPaid)</td>
                                        <td class="negative">@FormattingHelpers.FormatMoney(c.RemainingInterest)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private DebtSummaryResult? Summary;
    private List<UpcomingPaymentItem>? Upcoming;
    private List<PaymentWithDebtName>? History;
    private services.Models.PaidVsPendingResult? PaidVsPending;
    private List<DebtInterestItem>? InterestCost;

    private Guid UserId;

    protected override async Task OnInitializedAsync()
    {
        var userId = await AuthHelper.GetUserIdOrRedirect(AuthState, Nav);
        if (userId == null) return;
        UserId = userId.Value;

        try { Summary = await DashboardSvc.GetDebtSummaryAsync(UserId); } catch { Summary = new(); }
        try
        {
            var debts = await DashboardSvc.GetUpcomingPaymentsAsync(UserId);
            Upcoming = debts.Select(d => new UpcomingPaymentItem
            {
                DebtId = d.Id,
                DebtName = d.Name,
                Amount = d.MonthlyPayment,
                DueDate = d.DueDate,
                DaysUntilDue = Math.Max(0, (int)(d.DueDate.Date - DateTime.UtcNow.Date).TotalDays)
            }).ToList();
        }
        catch { Upcoming = new(); }

        try { History = (await PaymentService.GetPaymentHistoryWithDebtNameAsync(UserId)).ToList(); } catch { History = new(); }
        try { PaidVsPending = await DashboardSvc.GetPaidVsPendingAsync(UserId); } catch { PaidVsPending = new(); }
        try
        {
            var allDebts = await DashboardSvc.GetUpcomingPaymentsAsync(UserId);
            InterestCost = allDebts.Select(d =>
            {
                var monthlyRate = (double)(d.InterestRate / 100m / 12m);
                double balance = (double)d.CurrentBalance;
                double payment = (double)d.MonthlyPayment;
                var months = payment > 0 && monthlyRate > 0 && payment > balance * monthlyRate
                    ? (int)Math.Ceiling(Math.Log(payment / (payment - balance * monthlyRate)) / Math.Log(1 + monthlyRate))
                    : 0;
                var totalInterest = months > 0 ? (decimal)(months * payment - balance) : 0;
                return new DebtInterestItem
                {
                    Name = d.Name,
                    TotalInterestPaid = 0,
                    RemainingInterest = Math.Round(Math.Max(0, totalInterest), 2)
                };
            }).ToList();
        }
        catch { InterestCost = new(); }
    }

    private decimal PaidPct
    {
        get
        {
            if (PaidVsPending == null) return 0;
            var total = PaidVsPending.TotalPaid + PaidVsPending.TotalPending;
            return total > 0 ? Math.Round(PaidVsPending.TotalPaid / total * 100) : 0;
        }
    }
}
