@page "/login"
@layout Layout.BlankLayout
@inject AuthService Auth
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Iniciar sesión</PageTitle>

<div class="login-card">
    <h2>DebtsApp</h2>
    <p class="subtitle">Gestiona tus deudas y pagos</p>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger py-2 small">@Error</div>
    }

    @if (ShowRegister)
    {
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input @bind="Name" class="form-control" placeholder="Tu nombre" />
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Correo electrónico</label>
        <input type="email" @bind="Email" class="form-control" placeholder="correo@ejemplo.com" />
    </div>

    <div class="mb-4">
        <label class="form-label">Contraseña</label>
        <input type="password" @bind="Password" class="form-control" placeholder="••••••" />
    </div>

    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@Loading">
        @if (Loading)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            <span>@(ShowRegister ? "Registrando..." : "Ingresando...")</span>
        }
        else
        {
            <span>@(ShowRegister ? "Registrarse" : "Ingresar")</span>
        }
    </button>

    <div class="text-center mt-3">
        <a href="javascript:void(0)" @onclick="ToggleMode" class="text-muted small">
            @(ShowRegister ? "¿Ya tienes cuenta? Inicia sesión" : "¿No tienes cuenta? Regístrate")
        </a>
    </div>
</div>

@code {
    private string Email = "";
    private string Password = "";
    private string Name = "";
    private string Error = "";
    private bool Loading;
    private bool ShowRegister;

    private void ToggleMode()
    {
        ShowRegister = !ShowRegister;
        Error = "";
    }

    private async Task SubmitAsync()
    {
        Error = "";
        Loading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                Error = "El correo es requerido";
                return;
            }
            if (string.IsNullOrWhiteSpace(Password))
            {
                Error = "La contraseña es requerida";
                return;
            }

            if (ShowRegister)
            {
                if (string.IsNullOrWhiteSpace(Name))
                {
                    Error = "El nombre es requerido";
                    return;
                }
                await Auth.RegisterAsync(Email, Name, Password);
            }
            else
            {
                await Auth.LoginAsync(Email, Password);
            }

            await ((CustomAuthStateProvider)AuthState).NotifyAuthStateChanged();
            Nav.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }
}
